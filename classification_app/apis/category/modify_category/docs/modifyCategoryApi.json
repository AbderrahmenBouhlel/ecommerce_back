{
  "endpoint": "api/v1/admin/categories/{categoryId}",
  "method": "PATCH",
  "pathParams": {
    "categoryId": "long"
  },
  "body": {
    "name": "string (optional)",
    "description": "string (optional)"
  },
  "success": [
    {
      "status": 200,
      "body": {
        "timestamp": "2026-04-17T13:00:00Z",
        "code": "CATEGORY.UPDATED",
        "message": "Category updated successfully.",
        "data": {
          "id": "long",
          "name": "string",
          "gender": "string",
          "slug": "string",
          "description": "string",
          "isActive": "boolean",
          "createdAt": "datetime",
          "updatedAt": "datetime"
        }
      },
      "_developerHint": "Updates provided fields. If 'name' or 'gender' change, the 'slug' is automatically recalculated to maintain uniqueness."
    }
  ],
  "errors": [
    {
      "status": 400,
      "body": {
        "timestamp": "2026-04-17T13:00:00Z",
        "code": "REQUEST.INVALID",
        "message": "Invalid request parameters."
      },
      "_developerHint": "Triggered if 'gender' is not a valid choice or if required logic fails."
    },

    
    {
      "status": 401,
      "body": {
        "timestamp": "2026-01-21T13:00:00Z",
        "code": "AUTH.MISSING_TOKEN",
        "message": "Authentication token is required."
      }
    },
    {
      "status": 401,
      "body": {
        "timestamp": "2026-01-21T13:00:00Z",
        "code": "AUTH.EXPIRED_TOKEN",
        "message": "Authentication token has expired."
      }
    },
    {
      "status": 401,
      "body": {
        "timestamp": "2026-01-21T13:00:00Z",
        "code": "AUTH.INVALID_TOKEN",
        "message": "Invalid authentication token."
      }
    },

    {
      "status": 403,
      "body": {
        "timestamp": "2026-04-17T13:00:00Z",
        "code": "AUTH.UNAUTHORIZED_ACTION",
        "message": "You are not allowed to perform this action."
      },
      "_developerHint": "Only admin users can create filters."
    },




    {
      "status": 404,
      "body": {
        "timestamp": "2026-04-17T13:00:00Z",
        "code": "CATEGORY.NOT_FOUND",
        "message": "Category not found."
      }
    },
    {
      "status": 409,
      "body": {
        "timestamp": "2026-04-17T13:00:00Z",
        "code": "CATEGORY.ALREADY_EXISTS",
        "message": "A category with this name and gender combination already exists."
      },
      "_developerHint": "Triggered if the updated name/gender results in a slug conflict."
    },
    {
      "status": 500,
      "body": {
        "timestamp": "2026-04-17T13:00:00Z",
        "code": "SYSTEM.INTERNAL_ERROR",
        "message": "Internal server error."
      }
    }
  ]
}